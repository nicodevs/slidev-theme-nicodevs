{
  "name": "slidev-theme-nicodevs",
  "version": "0.1.0",
  "type": "module",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@slidev/types": "^52.14.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.14.1"
  },
  "slidev": {
    "colorSchema": "dark",
    "defaults": {
      "fonts": {
        "sans": "Space Grotesk",
        "mono": "JetBrains Mono"
      },
      "transition": "none"
    }
  }
}
